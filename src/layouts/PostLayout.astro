---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
const { title, date, description, image } = frontmatter;
---

<BaseLayout title={title} description={description} image={image}>
    <article>
        <header style="margin-bottom: 2rem;">
            <h1 style="margin-bottom: 0.5rem;">{title}</h1>
            {
                date && (
                    <time style="color: #666; font-size: 0.9rem;">{date}</time>
                )
            }
        </header>
        <div style="line-height: 1.8;">
            <slot />
        </div>
        <script>
            document.querySelectorAll("article h2[id], article h3[id]").forEach((heading) => {
                if (heading.querySelector("a[data-heading-link]")) return;
                const anchor = document.createElement("a");
                anchor.href = `#${heading.id}`;
                anchor.dataset.headingLink = "";
                anchor.textContent = heading.textContent ?? "";
                anchor.setAttribute("aria-label", `Link to ${anchor.textContent}`);
                heading.textContent = "";
                heading.append(anchor);
            });
        </script>
    </article>

    <style is:global>
        article h2 {
            margin-top: 1.25rem;
            margin-bottom: 1rem;
        }
        article h3 {
            margin-top: 1rem;
            margin-bottom: 0.75rem;
        }
        article h2 a[data-heading-link],
        article h3 a[data-heading-link] {
            color: var(--heading-ink);
            text-decoration: none;
        }
        article h2 a[data-heading-link]:hover,
        article h3 a[data-heading-link]:hover {
            text-decoration: underline;
            text-decoration-thickness: 1px;
            text-underline-offset: 0.2em;
        }
        article p {
            margin-bottom: 1rem;
        }
        article ul,
        article ol {
            margin-bottom: 1rem;
            margin-left: 2rem;
        }
        article li {
            margin-bottom: 0.5rem;
        }
        article pre {
            background: #f4f4f4;
            padding: 1rem;
            overflow-x: auto;
            border-radius: 4px;
            margin-bottom: 1rem;
        }
        article code {
            background: #f4f4f4;
            padding: 0.2rem 0.4rem;
            border-radius: 3px;
            font-size: 0.9em;
        }
        article pre code {
            background: none;
            padding: 0;
        }
        article table {
            width: 100%;
            margin-bottom: 1.5rem;
            border-collapse: collapse;
        }
        article th,
        article td {
            padding: 0.6rem 0.75rem;
            border: 1px solid var(--rule);
            text-align: left;
            vertical-align: top;
        }
        article th {
            background: var(--page-bg);
            color: var(--heading-ink);
            font-weight: 600;
        }
        article blockquote {
            border-left: 2px solid #9a8b62;
            color: #555;
            margin: 1.5rem 0 2rem;
            padding: 0.25rem 0 0.25rem 1.25rem;
            font-style: italic;
        }
        article blockquote p:last-child {
            margin-bottom: 0;
        }
        article blockquote:has(+ blockquote) {
            margin-bottom: 0.5rem;
        }
        article blockquote + blockquote {
            margin-top: 0;
        }
        article a[data-footnote-ref] {
            display: inline-block;
            min-width: 1.2em;
            margin-left: 0.1em;
            font-size: 0.75em;
            font-weight: 600;
            line-height: 1;
            text-align: center;
            text-decoration: none;
            vertical-align: super;
        }
        article .footnotes {
            margin-top: 3rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--rule);
            color: var(--muted-ink);
            font-size: 0.875rem;
            line-height: 1.65;
        }
        article .footnotes .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
        article .footnotes ol {
            margin: 0;
            padding-left: 1.5rem;
            list-style-position: outside;
        }
        article .footnotes li,
        article .footnotes p {
            margin-bottom: 0;
        }
        article a[data-footnote-backref] {
            margin-left: 0.2em;
            text-decoration: none;
        }
    </style>
</BaseLayout>
